generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ApprovalStatus {
  pending
  approved
  rejected
  changes_requested
}

enum WorkflowStatus {
  received
  processing
  awaiting_approval
  completed
  failed
}

enum NotificationType {
  info
  success
  warning
  error
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("member")
  organization  Organization?  @relation(fields: [organizationId], references: [id])
  organizationId String?
  submissions   Submission[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id               String      @id @default(cuid())
  name             String
  sector           String
  geography        String
  approvalMode     String      @default("human_required_for_high_risk")
  users            User[]
  submissions      Submission[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Submission {
  id               String             @id @default(cuid())
  title            String
  inputType        String
  sourceType       String
  sector           String?
  geography        String?
  urgency          String?
  opportunityType  String?
  description      String
  rawContent       String
  status           String             @default("received")
  user             User?              @relation(fields: [userId], references: [id])
  userId           String?
  organization     Organization?      @relation(fields: [organizationId], references: [id])
  organizationId   String?
  signal           Signal?
  intelligenceBrief IntelligenceBrief?
  venture          Venture?
  positioningDocument PositioningDocument?
  reports          Report[]
  workflowLogs     WorkflowLog[]
  notifications    Notification[]
  automationRuns   AutomationRun[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Signal {
  id             String      @id @default(cuid())
  submission     Submission  @relation(fields: [submissionId], references: [id])
  submissionId   String      @unique
  classification String
  inputType      String
  sourceType     String
  sector         String
  geography      String
  urgency        String
  opportunityType String
  confidence     Float
  status         String      @default("captured")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model IntelligenceBrief {
  id                   String      @id @default(cuid())
  submission            Submission  @relation(fields: [submissionId], references: [id])
  submissionId          String      @unique
  strategicSummary      String
  opportunityGap        String
  policyRelevance       String
  riskAnalysis          String
  opportunityScore      Int
  recommendedVentureAngle String
  keySignals            String
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model Venture {
  id                String      @id @default(cuid())
  submission        Submission  @relation(fields: [submissionId], references: [id])
  submissionId      String      @unique
  name              String
  problemStatement  String
  solution          String
  targetMarket      String
  mvpPlan           String
  revenueModel      String
  validationPlan    String
  riskMatrix        String
  status            String      @default("generated")
  businessModel     BusinessModel?
  validationReport  ValidationReport?
  investorMatches   InvestorMatch[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model BusinessModel {
  id                      String   @id @default(cuid())
  venture                 Venture  @relation(fields: [ventureId], references: [id])
  ventureId               String   @unique
  revenueModel            String
  monetizationLevers      String
  costDrivers             String
  unitEconomicsAssumptions String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model ValidationReport {
  id                      String   @id @default(cuid())
  venture                 Venture  @relation(fields: [ventureId], references: [id])
  ventureId               String   @unique
  assumptions             String
  validationPlan          String
  risks                   String
  unitEconomicsAssumptions String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model PositioningDocument {
  id                      String      @id @default(cuid())
  submission              Submission  @relation(fields: [submissionId], references: [id])
  submissionId            String      @unique
  executiveSummary        String
  policyBrief             String
  investmentMemo          String
  pitchDeckOutline        String
  marketPositioningStatement String
  exportStatus            String
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model Investor {
  id              String           @id @default(cuid())
  name            String
  sectorFocus     String
  geographyFocus  String
  ticketSizeMin   Int
  ticketSizeMax   Int
  riskProfile     String
  notes           String
  mandates        InvestorMandate[]
  matches         InvestorMatch[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model InvestorMandate {
  id                      String   @id @default(cuid())
  investor                Investor @relation(fields: [investorId], references: [id])
  investorId              String
  sector                  String
  geography               String
  ticketSizeMin           Int
  ticketSizeMax           Int
  riskProfile             String
  capitalStructurePreference String
  thesis                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model InvestorMatch {
  id                      String   @id @default(cuid())
  venture                 Venture  @relation(fields: [ventureId], references: [id])
  ventureId               String
  investor                Investor @relation(fields: [investorId], references: [id])
  investorId              String
  matchScore              Int
  mandateFit              String
  investorFitNotes        String
  recommendedOutreachAngle String
  capitalStructureSuggestion String
  ticketSizeMin           Int
  ticketSizeMax           Int
  geography               String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model AutomationRun {
  id               String          @id @default(cuid())
  submission       Submission      @relation(fields: [submissionId], references: [id])
  submissionId     String
  status           String          @default("processing")
  currentStage     String
  progress         Int             @default(0)
  summary          String
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  steps            AutomationStep[]
  logs             WorkflowLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model AutomationStep {
  id               String         @id @default(cuid())
  automationRun    AutomationRun  @relation(fields: [automationRunId], references: [id])
  automationRunId  String
  stage            String
  status           String
  operator         String
  note             String
  startedAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model KnowledgeItem {
  id               String   @id @default(cuid())
  type             String
  refId            String
  title            String
  sector           String?
  geography        String?
  status           String?
  searchableText   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Report {
  id               String      @id @default(cuid())
  submission       Submission? @relation(fields: [submissionId], references: [id])
  submissionId     String?
  type             String
  title            String
  summary          String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model AIOperator {
  id               String   @id @default(cuid())
  name             String
  mandate          String
  inputType        String
  outputType       String
  recentActivity    String
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApprovalRequest {
  id               String         @id @default(cuid())
  type             String
  title            String
  description      String
  status           ApprovalStatus @default(pending)
  riskLevel        String
  reviewNote       String?
  relatedEntityId  String?
  reviewedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model WorkflowLog {
  id               String      @id @default(cuid())
  automationRunId  String?
  automationRun    AutomationRun? @relation(fields: [automationRunId], references: [id])
  submissionId     String?
  submission       Submission? @relation(fields: [submissionId], references: [id])
  message          String
  level            String
  operator         String
  stage            String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Notification {
  id               String      @id @default(cuid())
  submission       Submission? @relation(fields: [submissionId], references: [id])
  submissionId     String?
  title            String
  message          String
  type             NotificationType @default(info)
  read             Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}
